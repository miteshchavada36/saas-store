# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/saas-store

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d

# Twilio Configuration (for SMS/WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=noreply@pharmacypos.com

# Razorpay Configuration (Payment Gateway)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Application Configuration
APP_NAME=SaaS Pharmacy Store
APP_URL=http://localhost:5000

# GST/TAX Configuration
DEFAULT_GST_RATE=18
DEFAULT_VAT_RATE=5

# Logging
LOG_LEVEL=debug

# Session
SESSION_TIMEOUT=3600000

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=csv,pdf,xlsx